{
  "manifest_version": 3,
  "name": "ImageSnap: Asset & Metadata Scraper",
  "version": "1.2.0",
  "description": "Capture product images and metadata from any website directly to your Google Drive and Sheets.",
  "author": "ImageSnap Cloud",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/drive/*",
    "https://www.googleapis.com/oauth2/*",
    "https://www.googleapis.com/userinfo/*",
    "https://lh3.googleusercontent.com/*"
  ],
  "oauth2": {
    "client_id": "271749541534-0ohcjg65bmejf4gjhd4ve17quggp72q1.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file",
      "openid",
      "email",
      "profile"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
