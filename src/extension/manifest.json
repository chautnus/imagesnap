{
  "manifest_version": 3,
  "key": "",
  "name": "ImageSnap: Ecommerce Asset Collector",
  "version": "1.3.4",
  "description": "Snap product images and metadata from any website directly to your Google Drive and Sheets.",
  "author": "ImageSnap Cloud",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "identity",
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/drive/*",
    "https://www.googleapis.com/oauth2/*",
    "https://www.googleapis.com/userinfo/*",
    "https://lh3.googleusercontent.com/*",
    "https://www.imagesnap.cloud/*",
    "*://*/*"
  ],
  "oauth2": {
    "client_id": "271749541534-rntu3te08mtjbcfpeej8k32t5t36imne.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file",
      "openid",
      "email",
      "profile"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}