{
  "name": "imagesnap",
  "private": true,
  "version": "1.2.5",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server.ts",
